PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/voting_dapp

# Blockchain RPC (Hardhat local node)
RPC_URL=http://127.0.0.1:8545

# Deployed Voting contract address
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Private key used by the backend for admin transactions
ADMIN_PRIVATE_KEY=0xYourAdminPrivateKey

# Protect admin endpoints (do NOT expose this in the frontend)
ADMIN_API_KEY=change-me

# Optional: validate the chain id backend connects to
EXPECTED_CHAIN_ID=31337

